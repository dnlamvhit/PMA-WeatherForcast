# Weather API Key (e.g., OpenWeatherMap, WeatherStack)
WEATHER_API_KEY=your_api_key_here

# Database URL - Docker configuration
DATABASE_URL=sqlite:///./data/weather.db

# Server Config
PORT=8000
HOST=0.0.0.0

# Docker Environment
DOCKER_ENV=true
API_URL=http://backend:8000
NEXT_PUBLIC_API_URL=http://localhost:8000
